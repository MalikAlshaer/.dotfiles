# set specific apps to open floating by default
# use xprop to find the arguments needed
for_window [class="Thunar" instance="Thunar"] floating enable
for_window [class="Blueman-manager" instance="blueman-manager"] floating enable
for_window [class="org.gnome.FileRoller" instance="org.gnome.FileRoller"] floating enable
for_window [class="Nvidia-settings" instance="nvidia-settings"] floating enable
#for_window [class="Org.gnome.Evolution" instance="org.gnome.Evolution"] floating enable

# remove top bar thing for terminal
for_window [class="Alacritty"] border pixel 0

# SHORTCUTS:

# open brave
bindsym $mod+n exec brave-browser

# open alacritty
bindsym $mod+Return exec alacritty

# open bluetooth settings
bindsym $mod+Shift+b exec blueman-manager

# screen shot with printscreen
bindsym Print exec xfce4-screenshooter
